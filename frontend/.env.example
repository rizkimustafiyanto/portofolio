# Example environment variables for this Nuxt app
# Copy to .env or set in your hosting environment

# Public API base used by the frontend (readable in client).
# If omitted, nuxt.config derives it from NUXT_PUBLIC_API_HOST + NITRO_PORT/PORT.
NUXT_PUBLIC_API_BASE=http://localhost:3000

# Host used to derive apiBase fallback (client-facing). Default: localhost.
# Use this when your API is running on a different host than the frontend container.
NUXT_PUBLIC_API_HOST=localhost

# Runtime / dev server port settings.
# Most tooling respects PORT; Nitro also supports NITRO_PORT/NITRO_HOST.
PORT=3000
NITRO_PORT=3000
NITRO_HOST=0.0.0.0

NODE_ENV=development
